# Copy this file to .env and fill in your real key.
# Never commit .env to git.

OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 生成模型（默认 Qwen 旗舰 plus；想换回 DeepSeek 改成 deepseek/deepseek-chat 即可）
CHAT_MODEL=qwen/qwen3.7-plus
# 意图分类模型（小而快，负责 intent × risk × 检索改写的 JSON 输出）
INTENT_MODEL=qwen/qwen3.5-flash-02-23

EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
CHROMA_DIR=./chroma_data
SQLITE_PATH=./data/app.db

# ============ 管理端（强烈建议公网部署时设置）============
# 设置后 /admin/stats、/admin/export_excel 需带 X-Admin-Token 头或 ?token= 参数
ADMIN_TOKEN=

# ============ demo 账号（登录页"一键体验"，启动时自动创建）============
DEMO_USERNAME=demo
DEMO_PASSWORD=demo2026

# ============ SMTP（高风险预警邮件，可选）============
# 留空则 notifier 走 dev 模式：只把预警内容打印到终端，不真发邮件。
# QQ 邮箱: smtp.qq.com:465, 密码用"授权码"不是登录密码。
# 163 邮箱: smtp.163.com:465。
# Gmail: smtp.gmail.com:587, 用 App Password。
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_TO_EMAIL=
